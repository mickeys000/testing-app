---
import BaseLayout from "../../../layouts/base.astro";
---

<BaseLayout title="Vanilla Engines">
  <main class="min-h-screen grid place-items-center px-6">
    <section class="w-full max-w-xl space-y-4">
      <h1 class="text-3xl font-semibold">Select an engine</h1>
      <p class="text-muted-foreground">Framework: Vanilla</p>
      <nav class="grid gap-3" aria-label="Engine options">
        <a
          href="/frameworks/vanilla/engines/maplibre"
          class="rounded-md border border-border px-4 py-3 hover:bg-accent hover:text-accent-foreground"
        >
          MapLibre
        </a>
        <a
          href="/frameworks/vanilla/engines/leaflet"
          class="rounded-md border border-border px-4 py-3 hover:bg-accent hover:text-accent-foreground"
        >
          Leaflet
        </a>
        <a
          href="/frameworks/vanilla/engines/open-layers"
          class="rounded-md border border-border px-4 py-3 hover:bg-accent hover:text-accent-foreground"
        >
          Open Layers
        </a>
      </nav>
    </section>
  </main>
</BaseLayout>
