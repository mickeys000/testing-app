---
import BaseLayout from "../../layouts/base.astro";
---

<BaseLayout title="Frameworks">
  <main class="min-h-screen grid place-items-center px-6">
    <section class="w-full max-w-xl space-y-4">
      <h1 class="text-3xl font-semibold">Frameworks</h1>
      <p class="text-muted-foreground">Choose a framework to continue.</p>
      <nav class="grid gap-3" aria-label="Framework options">
        <a
          href="/frameworks/vanilla"
          class="rounded-md border border-border px-4 py-3 hover:bg-accent hover:text-accent-foreground"
        >
          Vanilla
        </a>
      </nav>
    </section>
  </main>
</BaseLayout>
