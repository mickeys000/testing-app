---
const collectionId = "ngd-base";
const apiKeyNgdTiles = import.meta.env.PUBLIC_API_KEY_NGD_TILES;
---

<article class="w-full h-full">
  <div
    data-api-key-ngd-tiles={apiKeyNgdTiles}
    data-collection-id={collectionId}
    id="map-openlayers"
    class="w-full h-full grow"
  >
  </div>
</article>

<script>
  import { applyStyle } from "ol-mapbox-style";
  import MVT from "ol/format/MVT.js";
  import VectorTileLayer from "ol/layer/VectorTile.js";
  import Map from "ol/Map.js";
  import VectorTileSource from "ol/source/VectorTile.js";
  import TileGrid from "ol/tilegrid/TileGrid.js";
  import View from "ol/View.js";
  import { fromLonLat, transformExtent } from "ol/proj.js";
  import "ol/ol.css";

  const mapElement = document.getElementById("map-openlayers");
  if (!mapElement) {
    throw new Error("Map container #map-openlayers not found");
  }

  const collectionId = mapElement.dataset.collectionId;
  const apiKeyNgdTiles = mapElement.dataset.apiKeyNgdTiles;
  if (!collectionId || !apiKeyNgdTiles) {
    throw new Error("Missing NGD tiles configuration on #map-openlayers");
  }

  const tileMatrixSetUrl =
    "https://api.os.uk/maps/vector/ngd/ota/v1/tilematrixsets/3857";
  const styleUrl = `https://api.os.uk/maps/vector/ngd/ota/v1/collections/${collectionId}/styles/3857`;

  Promise.all([
    fetch(tileMatrixSetUrl).then((response) => response.json()),
    fetch(styleUrl).then((response) => response.json()),
  ]).then(([tileMatrixSet, style]) => {
    const tileGrid = new TileGrid({
      resolutions: tileMatrixSet.tileMatrices.map(
        ({ cellSize }: { cellSize: number }) => cellSize,
      ),
      origin: tileMatrixSet.tileMatrices[0].pointOfOrigin,
      tileSize: [
        tileMatrixSet.tileMatrices[0].tileHeight,
        tileMatrixSet.tileMatrices[0].tileWidth,
      ],
    });

    const formatMvt = new MVT();
    formatMvt.supportedMediaTypes.push("application/octet-stream");

    style.sources[collectionId].tiles = [
      `https://api.os.uk/maps/vector/ngd/ota/v1/collections/${collectionId}/tiles/3857/{z}/{y}/{x}?key=${apiKeyNgdTiles}`,
    ];
    delete style.sources[collectionId].url;

    const vectorLayer = new VectorTileLayer({
      source: new VectorTileSource({
        url: `https://api.os.uk/maps/vector/ngd/ota/v1/collections/${collectionId}/tiles/3857/{z}/{y}/{x}?key=${apiKeyNgdTiles}`,
        format: formatMvt,
        tileGrid,
      }),
      declutter: true,
    });

    applyStyle(
      vectorLayer,
      style,
      { source: collectionId, updateSource: false },
      undefined,
      tileGrid.getResolutions(),
    );

    new Map({
      target: "map-openlayers",
      layers: [vectorLayer],
      view: new View({
        projection: "EPSG:3857",
        extent: transformExtent(
          [-8.74, 49.84, 1.96, 60.9],
          "EPSG:4326",
          "EPSG:3857",
        ),
        resolutions: tileGrid.getResolutions(),
        minZoom: 6,
        maxZoom: 19,
        center: fromLonLat([-0.1276, 51.5072]),
        zoom: 10,
      }),
    });
  });
</script>
