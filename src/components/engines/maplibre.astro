---
const collectionId = "ngd-base";
const apiKeyNgdTiles = import.meta.env.PUBLIC_API_KEY_NGD_TILES;
---

<article class="w-full h-full">
  <div
    id="map-maplibre"
    class="w-full h-full"
    data-api-key-ngd-tiles={apiKeyNgdTiles}
    data-collection-id={collectionId}
  >
  </div>
</article>

<script>
  const maplibregl = (window as any).maplibregl;
  if (!maplibregl) {
    throw new Error("maplibregl is not available on window");
  }

  const mapElement = document.getElementById("map-maplibre");
  if (!mapElement) {
    throw new Error("Map container #map-maplibre not found");
  }

  const collectionId = mapElement.dataset.collectionId;
  const apiKeyNgdTiles = mapElement.dataset.apiKeyNgdTiles;
  if (!collectionId || !apiKeyNgdTiles) {
    throw new Error("Missing NGD tiles configuration on #map-maplibre");
  }

  const styleUrl = `https://api.os.uk/maps/vector/ngd/ota/v1/collections/${collectionId}/styles/3857`;
  const tilesUrl = `https://api.os.uk/maps/vector/ngd/ota/v1/collections/${collectionId}/tiles/3857/{z}/{y}/{x}?key=${apiKeyNgdTiles}`;

  fetch(styleUrl)
    .then((response) => response.json())
    .then((style) => {
      if (!style?.sources?.[collectionId]) {
        throw new Error(`Source ${collectionId} not found in OS style`);
      }

      style.sources[collectionId].tiles = [tilesUrl];
      delete style.sources[collectionId].url;

      const mapLibre = new maplibregl.Map({
        container: "map-maplibre",
        style,
        center: [-0.1276, 51.5072],
        zoom: 7,
        maplibreLogo: true,
      });

      window.addEventListener("resize", () => {
        mapLibre.resize();
      });
    });
</script>
